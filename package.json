{
  "name": "cv",
  "version": "0.1.2",
  "description": "CV, portfolio, and blog site built with JSDA-Kit",
  "keywords": [
    "jsda",
    "jsda-kit",
    "symbiote.js",
    "portfolio",
    "blog",
    "github-pages"
  ],
  "homepage": "https://MakerDrive.github.io/cv/",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/MakerDrive/cv.git"
  },
  "license": "MIT",
  "author": "MakerDrive",
  "type": "module",
  "scripts": {
    "test": "npm run check:types",
    "check:types": "npx tsc --noEmit",
    "copy-robots": "cp ./src/static-pages/robots.txt ./dist/robots.txt",
    "write-material-symbols-css": "node ./scripts/write-material-symbols-css.js",
    "build": "npx jsda build && npm run copy-robots && npm run write-material-symbols-css"
  },
  "dependencies": {
    "@symbiotejs/symbiote": "3.8.0-webmcp.2",
    "jsda-kit": "1.5.3",
    "symbiote-ui": "0.3.0-alpha.24"
  },
  "overrides": {
    "@symbiotejs/symbiote": "$@symbiotejs/symbiote",
    "jsda-kit": "1.5.3"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "cloud-images-toolkit": "^1.3.2",
    "typescript": "^6.0.3"
  }
}
